# Copie para .env (na raiz) e preencha. NUNCA commite token ou segredo real neste ficheiro.
# Ver: skills/instagram-publisher/SKILL.md

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Opcional — só necessários para troca de token longa duração via URL OAuth
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# URL de redirecionamento OAuth (passo 4 Meta / Login da empresa no Instagram) — mesmo valor no painel + em URIs válidos:
# https://SEU_DOMINIO.vercel.app/meta/oauth/callback
# Desautorização (URL de retorno no painel Meta): https://SEU_DOMINIO.vercel.app/meta/deauthorize
# Exclusão de dados (URL de solicitação no painel Meta): https://SEU_DOMINIO.vercel.app/meta/data-deletion
# META_APP_SECRET= (opcional; valida signed_request na desautorização — pode usar o mesmo que INSTAGRAM_APP_SECRET)

# Webhook Meta — mesmo valor em "Verificar token" no Developers + variável no projeto Vercel
# META_WEBHOOK_VERIFY_TOKEN=escolha_uma_string_secreta_longa
