{
  "rewrites": [
    {
      "source": "/meta/oauth/callback",
      "destination": "/api/meta-oauth-callback"
    },
    {
      "source": "/meta/deauthorize",
      "destination": "/api/meta-deauthorize"
    },
    {
      "source": "/meta/data-deletion",
      "destination": "/api/meta-data-deletion"
    },
    {
      "source": "/meta-webhook",
      "destination": "/api/meta-webhook"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
